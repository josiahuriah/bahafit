# ─── Fygaro payment integration ─────────────────────────────────────────
# Server-only. NEVER prefix these with NEXT_PUBLIC_ — they would leak to
# the browser bundle if you do.

# JWT `kid` header. Identifies which key signed the token.
FYGARO_API_KEY=

# HMAC-SHA256 signing key. Treat like a password.
FYGARO_API_SECRET=

# Public URL of the payment button you create in the Fygaro dashboard.
# Looks like: https://www.fygaro.com/en/pb/<uuid>
FYGARO_PAYMENT_BUTTON_URL=

# Optional: separate secret for verifying inbound webhook signatures.
# If unset, FYGARO_API_SECRET is used.
FYGARO_WEBHOOK_SECRET=

# ─── App URLs ───────────────────────────────────────────────────────────
# Used to build success/cancel return URLs sent to Fygaro.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Coming Soon mode ───────────────────────────────────────────────────
# When set to "true", every request that isn't from a signed-in admin is
# redirected to /coming-soon. Admin sign-in (/auth/signin) and the NextAuth
# API stay reachable so you can log in to see the real site.
# Flip to "false" (or unset) to launch.
COMING_SOON_MODE=false
